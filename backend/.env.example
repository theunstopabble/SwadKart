# 🔥 SwadKart Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server
PORT=8000
NODE_ENV=development

# MongoDB (Use Standard Connection String for Atlas - avoids SRV DNS issues)
MONGO_URI=mongodb://username:password@host1:port1,host2:port2/database?ssl=true&replicaSet=...&authSource=admin

# JWT (MUST be at least 32 chars, use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secure_random_jwt_secret_here_at_least_32_chars

# Razorpay (Use TEST keys for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brevo (Sendinblue) Email
BREVO_API_KEY=xkeysib-your_api_key
SMTP_MAIL=your_email@example.com

# Sender (from-address) for outgoing email. Use a verified custom domain
# (e.g. noreply@swadkart.com) for best deliverability. Falls back to SMTP_MAIL.
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=SwadKart Support

# SMTP Fallback (used when Brevo is unavailable; e.g. Gmail, Outlook, AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_PASSWORD=your_app_password

# Groq AI
GROQ_API_KEY=gsk_your_groq_api_key

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Redis (Optional - falls back to in-memory)
REDIS_URL=rediss://default:password@host:port

# Firebase Admin (paste full JSON on one line, or use base64)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# WebAuthn (Biometric Login)
RP_ID=localhost
RP_NAME=SwadKart

# OpenWA (WhatsApp API Gateway - self-hosted)
# Generate key: node backend/scripts/generate-openwa-key.js
OPENWA_BASE_URL=http://localhost:2785
OPENWA_API_KEY=owa_k1_your_openwa_api_key
OPENWA_WEBHOOK_SECRET=your_webhook_hmac_secret
OPENWA_TIMEOUT_MS=15000
OPENWA_MAX_RETRIES=2
OPENWA_DEFAULT_SESSION=default
OPENWA_ISOLATE_SESSIONS=true
OPENWA_ALLOWED_IPS=
OPENWA_RATE_LIMIT=60
OPENWA_ENGINE_TYPE=baileys
OPENWA_PORT=2785
# PostgreSQL (for production profile in docker-compose.openwa.yml)
OPENWA_DB_TYPE=sqlite
OPENWA_PG_DB=openwa
OPENWA_PG_USER=openwa
OPENWA_PG_PASSWORD=
OPENWA_MINIO_USER=openwa
OPENWA_MINIO_PASSWORD=
